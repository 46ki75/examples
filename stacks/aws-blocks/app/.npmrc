# AWS Blocks' generated aws-blocks/client.js imports its @aws-blocks/bb-*
# sub-packages directly (e.g. @aws-blocks/bb-realtime/mock-middleware) as
# transitive deps of @aws-blocks/blocks, not declared deps of this project.
# pnpm's default strict linking blocks that; shamefully-hoist restores flat
# node_modules resolution (same tradeoff npm/yarn classic always made) while
# keeping pnpm's content-addressable store.
shamefully-hoist=true
