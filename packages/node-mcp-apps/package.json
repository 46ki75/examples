{
  "name": "node-mcp-apps",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Minimal MCP Apps example: a React UI backed by an in-memory to-do list",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "serve": "tsx server.ts",
    "serve:stdio": "tsx server.ts --stdio",
    "start": "pnpm build && pnpm serve"
  },
  "dependencies": {
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^6.0.0",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
