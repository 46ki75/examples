{
  "name": "node-mcp-apps",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Minimal MCP Apps example: a React UI backed by an in-memory to-do list",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "serve": "tsx server.ts",
    "serve:stdio": "tsx server.ts --stdio",
    "start": "pnpm build && pnpm serve"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "hono": "^4.12.28",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "vite": "^8.1.4",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
