{
  "name": "node-mcp-apps-wordle",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "MCP Apps Wordle: a shared game playable by both humans (UI) and agents (tools)",
  "scripts": {
    "build": "tsc --noEmit && vite build",
    "serve": "tsx server.ts",
    "serve:stdio": "tsx server.ts --stdio",
    "start": "pnpm build && pnpm serve"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@modelcontextprotocol/ext-apps": "^1.7.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "consola": "^3.4.2",
    "hono": "^4.12.27",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^6.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "^8.1.2",
    "vite-plugin-singlefile": "^2.3.0"
  }
}
